        // Close popup when clicking overlay
        document.getElementById('awsConfigPopup').onclick = function(e) {
            if (e.target === this) {
                closeAwsConfig();
            }
        }
        
        document.getElementById('userInfoPopup').onclick = function(e) {
            if (e.target === this) {
                closeUserInfo();
            }
        }
        
        function openUserInfo() {
            document.getElementById('userInfoPopup').style.display = 'block';
        }
        
        function closeUserInfo() {
            document.getElementById('userInfoPopup').style.display = 'none';
        }
        
        function togglePassword() {
            const passwordField = document.getElementById('userPassword');
            const toggleBtn = document.querySelector('.password-toggle');
            
            if (passwordField.type === 'password') {
                passwordField.type = 'text';
                toggleBtn.textContent = '🙈';
            } else {
                passwordField.type = 'password';
                toggleBtn.textContent = '👁';
            }
        }
        
        function saveUserInfo() {
            const email = document.getElementById('userEmail').value;
            const password = document.getElementById('userPassword').value;
            
            if (!email || !password) {
                showAlert('Please enter both email and password', 'warning');
                return;
            }
            
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(email)) {
                showAlert('Please enter a valid email address', 'error');
                return;
            }
            
            // Save to localStorage
            storeData('userInfo', {
                email: email,
                password: password
            });
            
            closeUserInfo();
            showAlert('User information saved successfully!', 'success');
        }
        
        function clearUserInfo() {
            document.getElementById('userEmail').value = '';
            document.getElementById('userPassword').value = '';
            
            // Clear from localStorage
            localStorage.removeItem('userInfo');
        }
        
